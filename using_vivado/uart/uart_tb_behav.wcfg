<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="uart_tb_behav.wdb" id="1">
         <top_modules>
            <top_module name="uart_tb" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0.000 ns"></ZoomStartTime>
      <ZoomEndTime time="300.001 ns"></ZoomEndTime>
      <Cursor1Time time="300.000 ns"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="146"></NameColumnWidth>
      <ValueColumnWidth column_width="119"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="7" />
   <wvobject fp_name="/uart_tb/clk" type="logic">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
   </wvobject>
   <wvobject fp_name="/uart_tb/reset" type="logic">
      <obj_property name="ElementShortName">reset</obj_property>
      <obj_property name="ObjectShortName">reset</obj_property>
   </wvobject>
   <wvobject fp_name="/uart_tb/start" type="logic">
      <obj_property name="ElementShortName">start</obj_property>
      <obj_property name="ObjectShortName">start</obj_property>
   </wvobject>
   <wvobject fp_name="/uart_tb/TxD" type="logic">
      <obj_property name="ElementShortName">TxD</obj_property>
      <obj_property name="ObjectShortName">TxD</obj_property>
   </wvobject>
   <wvobject fp_name="/uart_tb/done" type="logic">
      <obj_property name="ElementShortName">done</obj_property>
      <obj_property name="ObjectShortName">done</obj_property>
   </wvobject>
   <wvobject fp_name="/uart_tb/txdata" type="array">
      <obj_property name="ElementShortName">txdata[7:0]</obj_property>
      <obj_property name="ObjectShortName">txdata[7:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/uart_tb/clk_period" type="other">
      <obj_property name="ElementShortName">clk_period</obj_property>
      <obj_property name="ObjectShortName">clk_period</obj_property>
   </wvobject>
</wave_config>
